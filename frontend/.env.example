# Backend API URL (default: http://127.0.0.1:8000)
# Use a different port if 8000 is already in use, e.g. when running uvicorn with --port 8002
VITE_API_URL=http://127.0.0.1:8000

# Google OAuth Client ID (Web application) from Google Cloud Console.
# Copy this file to ".env" and paste your real Client ID below.
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
